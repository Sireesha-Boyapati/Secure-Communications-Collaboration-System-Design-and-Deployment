# Copy to backend/.env on EC2 — never commit with real values.

APP_NAME=StudySafe
ENVIRONMENT=production
LOG_LEVEL=INFO

# Replace with your EC2 public IP — MUST use https (Web Crypto requires secure context)
CORS_ORIGINS=https://YOUR_EC2_PUBLIC_IP

# MongoDB Atlas (free M0) — whitelist EC2 public IP in Atlas Network Access
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=studysafe

# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# Email — Gmail SMTP (works on EC2; same as local demo)
EMAIL_FROM=mpshabade@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mpshabade@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# AWS SES — optional; leave empty if using SMTP above
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

RATE_LIMIT_PER_MINUTE=60
