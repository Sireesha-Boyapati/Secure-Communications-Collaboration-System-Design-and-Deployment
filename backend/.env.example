# Application
APP_NAME=StudySafe
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=studysafe

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# OTP
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# Email — pick ONE: AWS SES (production) OR Gmail SMTP (if SES verification blocked)
EMAIL_FROM=noreply@studysafe.local

# Option A: AWS SES (requires verified identity in same region)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Option B: Gmail SMTP (works when college/DBS blocks AWS verification emails)
# 1. Google Account → Security → 2-Step Verification ON
# 2. App passwords → generate for "Mail"
# 3. Set EMAIL_FROM and SMTP_USER to your Gmail; paste app password below
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourname@gmail.com
# SMTP_PASSWORD=your-16-char-app-password

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
